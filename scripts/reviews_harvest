from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.chrome.options import Options
import time 
import csv 
import os
import random



options = Options()
#options.add_argument("--headless")
options.add_argument("--no-sandbox")
options.add_argument("--disable-dev-shm-usage")
options.add_argument("--user-agent=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36")

driver = webdriver.Chrome(options=options) 

def scrape_trustpilot_reviews(company, page_no):
    url = f"https://www.trustpilot.com/review/www.steampowered.com?page={page_no}"
    print(f"URL: {url}")

    driver.get(url)
    time.sleep(3) # Wait for the page to load

    print(f"Scraping page {page_no}")

    try:
        reviews_list = driver.find_element(By.XPATH, "//div[@data-reviews-list-start='true']")
        reviews = reviews_list.find_elements(By.TAG_NAME, "article")

        print(f"Found {len(reviews)} reviews")
        
        # If no reviews are found on the page, return an empty list
        if len(reviews) == 0:
            return []

        data = [] 

        for review in reviews:
            try:
                title_tag = review.find_element(By.XPATH, ".//h2[@data-service-review-title-typography='true']")
                title = title_tag.text 
                rating_tag = review.find_element(By.XPATH, ".//div[@data-service-review-rating]")
                rating = rating_tag.get_attribute('data-service-review-rating')
                content_tag = review.find_element(By.XPATH, ".//p[@data-service-review-text-typography='true']")
                content = content_tag.text

                data.append([title, rating, content])
            
            except:
                print("One review was invalid or missing elements")

        return data 

    except Exception as e:
        print(f"Error on page {page_no}: {e}")
        return [] # Return empty list on failure so the loop can exit smoothly


# 1. Navigate to the main page first
print("Opening Trustpilot for manual login...")
driver.get("https://www.trustpilot.com/")

# 2. PAUSE THE SCRIPT
input("Please log in to Trustpilot in the open browser window. Once you are fully logged in, come back to this terminal and press ENTER to start scraping...")

company = "steam"

scripts_directory = os.path.dirname(os.path.abspath(__file__))
main_directory = os.path.dirname(scripts_directory)
export_directory = os.path.join(main_directory, "reviews_export")
os.makedirs(export_directory, exist_ok=True)
filename = os.path.join(export_directory, f"{company}.csv")

# Using 'with open' is best practice, and adding encoding='utf-8' prevents errors with emojis in reviews
with open(filename, 'w', newline='', encoding='utf-8') as file:
    csv_file = csv.writer(file)
    csv_file.writerow(['title', 'rating', 'review'])

    page_no = 1 # Start at page 1
    
    while page_no <= 123: # This will loop exactly 123 times
        data = scrape_trustpilot_reviews(company, page_no)

        # If data is empty, we've likely hit the last page
        if not data:
            print("No more reviews found or reached the end. Exiting...")
            break

        for row in data:
            csv_file.writerow(row)

        page_no += 1 # Move to the next page
        
        # Add a delay between pages to avoid being rate-limited or blocked
        sleep_time = random.uniform(5.0, 10.0)
        time.sleep(sleep_time)

driver.quit() # Close the browser when completely finished

